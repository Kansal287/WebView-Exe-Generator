{
  "name": "skillgame",
  "version": "2.0.0",
  "description": "Skill Game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.skillgame.app",
    "productName": "Skill Game",
    "icon": "chip.ico",
    "win": {
      "target": "nsis",
      "icon": "chip.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Skill Game"
    }
  },
  "devDependencies": {
    "electron": "^39.2.1",
    "electron-builder": "^26.0.12"
  }
}
